@page "/"
@using Syncfusion.Blazor
@using Syncfusion.Blazor.Navigations
@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Inputs
@inject NavigationManager Nav
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider

 

 
 
<!-- FEATURES, PRICING, TESTIMONIALS, CONTACT -->
<!-- (همان کد اصلی بدون تغییر) -->

@code {
    private bool IsLoggedIn;

    protected override async Task OnInitializedAsync()
    {
        // بررسی وضعیت لاگین هنگام بارگذاری صفحه
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        IsLoggedIn = authState.User.Identity?.IsAuthenticated ?? false;
    }

    private void GoToPageAfterLogin(string returnUrl)
    {
        if (IsLoggedIn)
        {
            // کاربر لاگین است → مستقیم به مسیر برود
            Nav.NavigateTo(returnUrl, true);
        }
        else
        {
            // کاربر لاگین نیست → به صفحه لاگین با پارامتر returnUrl هدایت شود
            Nav.NavigateTo($"/login?returnUrl={Uri.EscapeDataString(returnUrl)}");
        }
    }

    private async Task LoginLogout()
    {
        if (IsLoggedIn)
        {
            // خروج از سامانه
            if (AuthStateProvider is SimpleAuthProvider simpleAuth)
            {
                await simpleAuth.LogoutAsync();
            }

            IsLoggedIn = false;
            Nav.NavigateTo("/", true);
        }
        else
        {
            // هدایت به صفحه لاگین
            Nav.NavigateTo("/login");
        }
    }

 
}