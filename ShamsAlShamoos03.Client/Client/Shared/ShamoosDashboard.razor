@using Microsoft.AspNetCore.Components.Authorization
@using Syncfusion.Blazor.Navigations
@using System.Security.Claims
@inject NavigationManager Navigation
@inject HttpClient Http
<HeadContent>
    <link href="/ThemeSite/Css/ShamoosDashboard.css" rel="stylesheet" />
</HeadContent>

<div class="dashboard-container" dir="rtl">

    <SfSidebar Width="280px"
               Position="SidebarPosition.Right"
               Type="SidebarType.Over"
               IsOpen="@SidebarOpen">

        <ChildContent>

            <div class="sidebar-header">

                <img src="@UserImage"
                     class="user-avatar"
                     alt="User"
                     onerror="this.src='/images/default-user.png'" />

                <div class="user-info">
                    <div class="user-name">@UserFullName</div>
                    <div class="user-role">@UserRole</div>
                </div>

            </div>

            <div class="sidebar-menu">
                @foreach (var item in MenuItems)
                {
                    <div class="menu-item @(IsActive(item.Url) ? "active" : "")"
                         @onclick="() => NavigateTo(item.Url)">

                        <span class="e-icons @item.Icon"></span>
                        <span>@item.Title</span>

                    </div>
                }
            </div>

        </ChildContent>

    </SfSidebar>

    <div class="content">
        @ChildContent
    </div>

    <button class="toggle-btn @(SidebarOpen ? "opened" : "closed")"
            @onclick="ToggleSidebar">

        <span class="menu-icon">
            @(SidebarOpen ? "❯" : "❮")
        </span>

    </button>

</div>

@code {

    [CascadingParameter] 
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private bool SidebarOpen = true;

    private string UserFullName = "";
    private string UserRole = "";
    private string UserImage = "";
 
    protected override async Task OnInitializedAsync()
    {
        var currentUser =
            await Http.GetFromJsonAsync<Currentuser>("api/auth/current-user");

        if (currentUser is null)
            return;

        UserFullName = currentUser.FullName;
        UserRole = currentUser.RoleName;
        UserImage = currentUser.UserImage;

        MenuItems = new()
    {
        new("صفحه اصلی", "e-home", "/"),
        new("داشبورد", "e-dashboard", "/dashboard"),
        new("پرسنل", "e-user", "/personnel"),
        new("مکاتبات", "e-folder", "/letters"),
        new("گزارشات", "e-description", "/reports"),
        new("تنظیمات", "e-settings", "/settings"),
        new("صفحه یافت نشد", "e-PageNotFound", "/PageNotFound"),
        new("Panel02", "e-Panel02", "/Panel02")
    };

        if (currentUser.Roles.Contains("MANAGEUSER01")
            || currentUser.Roles.Contains("MANAGEUSER02"))
        {
            MenuItems.Add(
                new("Panel03", "e-Panel03", "/Panel03"));
        }
        if (currentUser.Roles.Contains("PersonalCorrespondenceYEGAN")
            || currentUser.Roles.Contains("PersonalCorrespondenceVazifeh"))
        {
            MenuItems.Add(
                new("Panel04", "e-Panel04", "/Panel04"));
        }
    }
    private List<MenuItem> MenuItems = new();

    private void ToggleSidebar() => SidebarOpen = !SidebarOpen;

    private void NavigateTo(string url) => Navigation.NavigateTo(url);

    private bool IsActive(string url)
    {
        var currentPath = Navigation.ToBaseRelativePath(Navigation.Uri);
        if (url == "/") return string.IsNullOrEmpty(currentPath);
        return currentPath.StartsWith(url.TrimStart('/'), StringComparison.OrdinalIgnoreCase);
    }

    private record MenuItem(string Title, string Icon, string Url);
}