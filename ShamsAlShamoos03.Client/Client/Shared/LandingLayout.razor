@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization

<div class="landing-layout">

    @* Preloader *@
    @if (IsLoading)
    {
        <div class="preloader">
            <div class="loader">
                <div class="shadow"></div>
                <div class="box"></div>
            </div>
        </div>
    }

    @* Header *@
    <Header @ref="HeaderComponent" />

    @* Search Overlay *@
    <SearchOverLay @ref="SearchOverlayComponent" />

    @* Banner *@
    <Banner />

    <main>
        @Body
    </main>

    @* Footer *@
    <Footer />

    <div class="go-top"><i class='bx bx-up-arrow-alt'></i></div>
</div>

@code {
    private bool IsLoading { get; set; } = true;

    private SearchOverLay SearchOverlayComponent;
    private Header HeaderComponent;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // شبیه‌سازی زمان بارگذاری (می‌توانید با بارگذاری داده واقعی جایگزین کنید)
            await Task.Delay(1000);
            IsLoading = false;
            StateHasChanged();
        }
    }

    // متد کمکی برای باز/بسته کردن Search Overlay از Header
    public void ToggleSearchOverlay()
    {
        SearchOverlayComponent?.ToggleSearch();
    }


}