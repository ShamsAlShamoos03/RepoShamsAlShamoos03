@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<header class="header-area">

    <div class="top-header">
        <div class="container">
            <div class="row align-items-center">

                <div class="col-lg-8">
                    <ul class="top-header-contact-info">
                        <li>
                            <i class='bx bx-phone-call'></i>
                            <span>تماس پشتیبانی</span>
                            <a href="tel:09151216302">09151216302</a>
                        </li>

                        <li>
                            <i class='bx bx-map'></i>
                            <span>مکان ما</span>
                            <a href="#">ایران ، مشهد</a>
                        </li>

                        <li>
                            <i class='bx bx-envelope'></i>
                            <span>پشتیبانی داخلی</span>
                            <a>56161</a>
                        </li>
                    </ul>
                </div>

                <div class="col-lg-4">
                    <div class="top-header-btn" style="gap:10px;">

                        <AuthorizeView>
                            <Authorized>
                                <a href="/Shamoos/Pages/HistoryRegister"
                                   class="default-btn">
                                    <i class='bx bx-log-in icon-arrow before'></i>
                                    <span class="label">پنل کاربری</span>
                                    <i class="bx bx-log-in icon-arrow after"></i>
                                </a>

                                <button class="default-btn"
                                        @onclick="Logout">
                                    <i class='bx bx-log-out icon-arrow before'></i>
                                    <span class="label">خروج</span>
                                    <i class="bx bx-log-out icon-arrow after"></i>
                                </button>
                            </Authorized>

                            <NotAuthorized>
                                <a href="/login"
                                   class="default-btn">
                                    <i class='bx bx-log-in icon-arrow before'></i>
                                    <span class="label">ورود</span>
                                    <i class="bx bx-log-in icon-arrow after"></i>
                                </a>
                            </NotAuthorized>
                        </AuthorizeView>

                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- Navbar -->
    <div class="navbar-area">
        <div class="raque-responsive-nav">
            <div class="container">
                <div class="raque-responsive-menu">
                    <div class="logo">
                        <a href="/">
                            <img src="/ThemeSite/assets/img/black-logo.png" alt="logo">
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="raque-nav">
            <div class="container">
                <nav class="navbar navbar-expand-md navbar-light">
                    <a class="navbar-brand" href="/">
                        <img src="/ThemeSite/assets/img/black-logo.png" alt="logo">
                    </a>

                    <div class="collapse navbar-collapse mean-menu">
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <NavLink href="/"
                                         Match="NavLinkMatch.All"
                                         class="nav-link">
                                    خانه
                                </NavLink>
                            </li>
                        </ul>

                        <div class="others-option">
                            <div class="dropdown language-switcher d-inline-block">
                                <button class="dropdown-toggle" type="button">
                                    <img src="/ThemeSite/assets/img/iran-flag.jpg"
                                         class="shadow" alt="image">
                                    <span>
                                        فا
                                        <i class='bx bx-chevron-down'></i>
                                    </span>
                                </button>
                            </div>

                            <div class="search-box d-inline-block">
                                <i class='bx bx-search'></i>
                            </div>
                        </div>
                    </div>
                </nav>
            </div>
        </div>
    </div>

</header>

@code {
    private async Task Logout()
    {
        if (AuthStateProvider is SimpleAuthProvider simpleAuth)
        {
            await simpleAuth.LogoutAsync();
        }

        Nav.NavigateTo("/", true);
    }
}